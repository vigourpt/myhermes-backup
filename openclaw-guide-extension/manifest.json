{
  "manifest_version": 3,
  "name": "OpenClaw Setup Guide",
  "version": "1.0.0",
  "description": "Contextual guide and AI assistant for OpenClaw Control UI - explains settings, configurations, and helps you set up channels, agents, skills, and more.",
  "permissions": ["sidePanel", "activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:18789/*", "http://localhost:18789/*", "http://187.124.114.207:45397/*", "https://github.com/*"],
  "action": {
    "default_title": "Open OpenClaw Guide",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:18789/*", "http://localhost:18789/*", "http://187.124.114.207:45397/*"],
      "js": ["scripts/content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "default_locale": "en"
}
